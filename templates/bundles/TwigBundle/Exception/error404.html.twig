{# Hérite du layout principal pour conserver le design global. #}
{% extends 'base.html.twig' %}
{# Définit le titre de la page 404. #}
{% block title %}Page introuvable (404) - Atlas CMS{% endblock %}
{# Définit le contenu principal de l'erreur 404. #}
{% block body %}
    {# Ouvre la section d'erreur. #}
    <section class="py-5">
        {# Ouvre le conteneur Bootstrap. #}
        <div class="container">
            {# Ouvre la ligne centrée. #}
            <div class="row justify-content-center">
                {# Ouvre la colonne responsive. #}
                <div class="col-12 col-lg-8">
                    {# Ouvre la carte d'erreur. #}
                    <div class="error-card shadow-sm border-0 p-4 p-md-5 text-center">
                        {# Affiche l'icône d'erreur 404. #}
                        <p class="display-5 fw-bold text-primary mb-2">404</p>
                        {# Affiche le titre explicatif. #}
                        <h1 class="h3 mb-3">Page introuvable</h1>
                        {# Affiche la description utilisateur. #}
                        <p class="text-muted mb-4">La page demandée n’existe pas ou a été déplacée.</p>
                        {# Ouvre le groupe d'actions. #}
                        <div class="d-flex justify-content-center gap-2 flex-wrap">
                            {# Affiche le bouton retour accueil. #}
                            <a href="{{ path('home') }}" class="btn btn-primary">Retour à l’accueil</a>
                            {# Affiche le bouton blog. #}
                            <a href="{{ path('front_blog_index') }}" class="btn btn-outline-primary">Aller au blog</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}

