{# Open reusable gallery card. #}
<article class="card front-card h-100 border-0">
    {# Open card body. #}
    <div class="card-body p-4 position-relative">
        {# Show gallery title. #}
        <h3 class="front-card-title h6 mb-2">{{ gallery.name }}</h3>
        {# Show gallery description fallback. #}
        <p class="front-card-text small mb-3">{{ gallery.description ?: 'Collection visuelle du CMS.' }}</p>
        {# Show image count badge. #}
        <p class="small mb-3"><span class="badge text-bg-light border">{{ gallery.images|length }} image(s)</span></p>
        {# Show gallery detail link. #}
        <a class="stretched-link text-decoration-none" href="{{ path('front_gallery_show', {id: gallery.id, slug: gallery.name|lower|replace({' ': '-', '/': '-'})}) }}">Explorer</a>
    </div>
</article>
