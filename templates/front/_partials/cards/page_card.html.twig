{# Open reusable page card. #}
<article class="card front-card h-100 border-0">
    {# Open card body. #}
    <div class="card-body p-4 position-relative">
        {# Show category badge when available. #}
        {% if page.category %}
            <span class="ui-chip mb-3">{{ page.category.name }}</span>
        {% endif %}
        {# Show page title. #}
        <h3 class="front-card-title h5 mb-2">{{ page.title }}</h3>
        {# Show page teaser text. #}
        <p class="front-card-text small mb-3">{{ page.metaDescription ?: 'Page institutionnelle publiee.' }}</p>
        {# Show detail link. #}
        <a class="stretched-link text-decoration-none" href="{{ path('front_page_show', {slug: page.slug}) }}">Lire la page</a>
    </div>
</article>
