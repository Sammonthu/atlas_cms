{# Open global footer. #}
<footer class="front-footer mt-auto py-4">
    {# Open centered footer container. #}
    <div class="container d-flex flex-column flex-lg-row justify-content-between align-items-center gap-3">
        {# Show copyright text. #}
        <small class="text-muted">&copy; {{ 'now'|date('Y') }} Atlas CMS. Interface front premium sous Symfony.</small>
        {# Open quick footer links. #}
        <div class="d-flex align-items-center gap-3">
            {# Show anchor to pages list. #}
            <a class="small text-decoration-none" href="{{ path('front_page_index') }}">Pages</a>
            {# Show anchor to blog list. #}
            <a class="small text-decoration-none" href="{{ path('front_blog_index') }}">Blog</a>
            {# Show anchor to galleries list. #}
            <a class="small text-decoration-none" href="{{ path('front_gallery_index') }}">Galeries</a>
            {# Show anchor to top. #}
            <a class="small text-decoration-none" href="#top">Haut</a>
        </div>
    </div>
</footer>
