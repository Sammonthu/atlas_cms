{# Extend the global front layout. #}
{% extends 'base.html.twig' %}
{# Define page title for SEO. #}
{% block title %}Atlas CMS - Accueil{% endblock %}
{# Define page meta description. #}
{% set metaDescription = 'Bienvenue sur Atlas CMS : pages publiques, blog editorial et galeries photos.' %}
{# Define main page body. #}
{% block body %}
    {# Select the first recent gallery when available. #}
    {% set heroGallery = latestGalleries|first %}
    {# Select the first image of the selected gallery when available. #}
    {% set heroImage = heroGallery and heroGallery.images|length > 0 ? heroGallery.images|first : null %}
    {# Resolve hero image path for the media layer. #}
    {% set heroImagePath = heroImage ? asset(heroImage.filePath) : null %}

    {# Open premium visual hero section. #}
    <section class="front-hero front-hero--visual" aria-labelledby="homeHeroTitle">
        {# Render hero media only when an image exists. #}
        {% if heroImagePath %}
            {# Render full-bleed hero media. #}
            <img
                class="front-hero__media"
                src="{{ heroImagePath }}"
                alt="{{ heroImage.caption ?: 'Visuel principal Atlas CMS' }}"
                loading="eager"
                fetchpriority="high"
                decoding="async"
            >
        {% endif %}
        {# Render dark overlay for strong text readability. #}
        <div class="front-hero__overlay" aria-hidden="true"></div>
        {# Render ambient glow to enrich premium depth. #}
        <div class="front-hero__aura" aria-hidden="true"></div>
        {# Open centered hero content container. #}
        <div class="container position-relative">
            {# Open hero copy wrapper. #}
            <div class="front-hero__content reveal is-visible">
                {# Render hero contextual chip. #}
                <span class="ui-chip front-hero__chip mb-3">Atlas CMS - Interface editoriale premium</span>
                {# Render hero main heading. #}
                <h1 class="front-hero__title mb-3" id="homeHeroTitle">Publiez avec impact. Valorisez chaque contenu.</h1>
                {# Render concise hero supporting copy. #}
                <p class="front-hero__subtitle mb-4">Une experience moderne pour presenter pages, articles et galeries avec une qualite visuelle professionnelle.</p>
                {# Render primary hero CTA. #}
                <a class="btn btn-primary btn-lg front-hero__cta" href="{{ path('front_page_index') }}" aria-label="Decouvrir les contenus du CMS">Decouvrir le CMS</a>
            </div>
        </div>
    </section>

    {# Open recent pages section. #}
    <section class="ui-section">
        {# Open centered container. #}
        <div class="container">
            {# Open section header row. #}
            <div class="d-flex justify-content-between align-items-end mb-4 reveal">
                {# Render section title. #}
                <div>
                    {# Render section chip. #}
                    <span class="ui-chip mb-2">Pages</span>
                    {# Render heading. #}
                    <h2 class="ui-heading h2 mb-0">Pages recentes</h2>
                </div>
                {# Render section link. #}
                <a class="text-decoration-none" href="{{ path('front_page_index') }}">Tout voir</a>
            </div>
            {# Open cards grid. #}
            <div class="row g-4">
                {# Loop through recent pages. #}
                {% for page in latestPages %}
                    <div class="col-12 col-md-6 col-xl-4 reveal">
                        {% include 'front/_partials/cards/page_card.html.twig' with { page: page } only %}
                    </div>
                {% else %}
                    <p class="text-muted">Aucune page validee pour le moment.</p>
                {% endfor %}
            </div>
        </div>
    </section>

    {# Open recent articles section. #}
    <section class="ui-section ui-section-soft">
        {# Open centered container. #}
        <div class="container">
            {# Open section header row. #}
            <div class="d-flex justify-content-between align-items-end mb-4 reveal">
                {# Render section title group. #}
                <div>
                    {# Render section chip. #}
                    <span class="ui-chip mb-2">Blog</span>
                    {# Render heading. #}
                    <h2 class="ui-heading h2 mb-0">Articles recents</h2>
                </div>
                {# Render section link. #}
                <a class="text-decoration-none" href="{{ path('front_blog_index') }}">Tout voir</a>
            </div>
            {# Open cards grid. #}
            <div class="row g-4">
                {# Loop through recent articles. #}
                {% for article in latestArticles %}
                    <div class="col-12 col-md-6 col-xl-4 reveal">
                        {% include 'front/_partials/cards/article_card.html.twig' with { article: article } only %}
                    </div>
                {% else %}
                    <p class="text-muted">Aucun article valide pour le moment.</p>
                {% endfor %}
            </div>
        </div>
    </section>

    {# Open featured galleries section. #}
    <section class="ui-section">
        {# Open centered container. #}
        <div class="container">
            {# Open section header row. #}
            <div class="d-flex justify-content-between align-items-end mb-4 reveal">
                {# Render section title group. #}
                <div>
                    {# Render section chip. #}
                    <span class="ui-chip mb-2">Galeries</span>
                    {# Render heading. #}
                    <h2 class="ui-heading h2 mb-0">Galeries en vedette</h2>
                </div>
                {# Render section link. #}
                <a class="text-decoration-none" href="{{ path('front_gallery_index') }}">Tout voir</a>
            </div>
            {# Open cards grid. #}
            <div class="row g-4">
                {# Loop through galleries. #}
                {% for gallery in latestGalleries %}
                    <div class="col-12 col-md-6 col-xl-3 reveal">
                        {% include 'front/_partials/cards/gallery_card.html.twig' with { gallery: gallery } only %}
                    </div>
                {% else %}
                    <p class="text-muted">Aucune galerie disponible pour le moment.</p>
                {% endfor %}
            </div>
        </div>
    </section>
{% endblock %}
